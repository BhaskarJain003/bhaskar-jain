---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('thoughts')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			.section-title {
				font-size: 1.25em;
				font-weight: 600;
				margin: 0 0 0.5em 0;
				color: rgb(var(--black));
			}
			.section-subtitle {
				margin: 0 0 1.5em 0;
				color: rgb(var(--gray));
				font-size: 0.95em;
				line-height: 1.5;
			}
			.thoughts-list {
				list-style: none;
				margin: 0;
				padding: 0;
			}
			.thoughts-list li {
				margin-bottom: 1em;
			}
			.thoughts-list li:last-child {
				margin-bottom: 0;
			}
			.thought-item {
				text-decoration: none;
				color: inherit;
				display: block;
				padding: 1em 1.25em;
				border: 2px solid rgba(73, 106, 129, 0.35);
				border-radius: 12px;
				transition: border-color 0.2s ease, box-shadow 0.2s ease;
			}
			.thought-item:hover {
				border-color: var(--accent);
				box-shadow: 0 2px 8px rgba(var(--gray), 15%);
			}
			.thought-item:hover .thought-title {
				color: var(--accent);
			}
			.thought-title {
				font-size: 1.25em;
				font-weight: 600;
				margin: 0 0 0.25em 0;
				color: rgb(var(--black));
			}
			.thought-description {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.95em;
				line-height: 1.5;
			}
			.thought-date {
				margin: 0.25em 0 0 0;
				font-size: 0.85em;
				color: rgb(var(--gray));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h2 class="section-title">Thoughts</h2>
			<p class="section-subtitle">A collection of random things that I thought were interesting.</p>
			<ul class="thoughts-list">
				{
					posts.map((post) => (
						<li>
							<a href={`/thoughts/${post.id}/`} class="thought-item">
								<span class="thought-title">{post.data.title}</span>
								<p class="thought-description">{post.data.description}</p>
								<p class="thought-date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
	</body>
</html>
