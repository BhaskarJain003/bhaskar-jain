---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import profileImage from '../assets/Professional - Copy.jpg';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1 class="site-title">Bhaskar Jain</h1>
			<p class="first-paragraph">
				<span class="profile-image-wrapper">
					<Image src={profileImage} alt="Bhaskar Jain" width={240} height={240} class="profile-image" />
				</span>
				I'm an aerospace engineer and graduate researcher at Georgia Tech's Aerospace Systems Design Laboratory (ASDL). 
				I love learning and solving hard problems—whether that's designing test rigs, optimizing propulsion systems, 
				or building structures that can handle 10,000 lbf of thrust. My path into aerospace started with FIRST 
				robotics in high school, where I served as president and mentor, and has since taken me through internships 
				at NASA, Blue Origin (working on New Shepard propulsion), and SpaceX (supporting the fluids bunker for 
				Starship's launch mount).
			</p>
			<p>
				I hold a B.S. and M.S. in Aerospace Engineering from Georgia Tech, where I've also worked as a teaching 
				assistant for thermodynamics and fluid dynamics, led the test stand structures team for the Yellow Jacket 
				Space Program, and conducted research at the Ben T. Zinn Combustion Laboratory. I'm interested in 
				propulsion, structures, design, and the intersection of rigorous engineering with rapid iteration. 
				Feel free to explore my <a href="/thoughts">thoughts</a> and <a href="/projects">projects</a>, or connect 
				with me on <a href="https://www.linkedin.com/in/bhaskar-jain003/" target="_blank" rel="noopener noreferrer">LinkedIn</a> and <a href="https://github.com/BhaskarJain003" target="_blank" rel="noopener noreferrer">GitHub</a>.
			</p>

			<details class="quotes-section" open>
				<summary class="quotes-summary">Quotes</summary>

				<blockquote class="quote-card">
					<p>"Curiosity has its own reason for existing."</p>
					<cite>— Albert Einstein</cite>
				</blockquote>

				<blockquote class="quote-card">
					<p class="quote-source">Bhagavad-gītā (Chapter 2, Verse 47)</p>
					<p class="quote-text-devanagari">कर्मण्येवाधिकारस्ते मा फलेषु कदाचन ।<br />मा कर्मफलहेतुर्भूर्मा ते सङ्गोऽस्त्वकर्मणि ॥</p>
					<p class="quote-translation">"You have a right to perform your prescribed duties, but you are not entitled to the fruits of your actions. Never consider yourself to be the cause of the results of your activities, nor be attached to inaction."</p>
				</blockquote>

				<blockquote class="quote-card">
					<p>"Tell me and I forget, teach me and I may remember, involve me and I learn."</p>
					<cite>— Benjamin Franklin</cite>
				</blockquote>

				<blockquote class="quote-card">
					<p class="quote-source">Tattvārtha Sūtra 5.21</p>
					<p class="quote-text-devanagari">परस्परोपग्रहो जीवानाम्</p>
					<p class="quote-translation">"Souls render service to one another."</p>
				</blockquote>

				<blockquote class="quote-card">
					<p>"You cannot open a book without learning something."</p>
					<cite>— Confucius</cite>
				</blockquote>

				<blockquote class="quote-card">
					<p class="quote-source">Dhammapada (Chapter 1, Verse 1)</p>
					<p class="quote-text-devanagari">मनोपुब्बङ्गमा धम्मा मनोसेट्ठा मनोमया ।</p>
					<p class="quote-translation">"Mind precedes all mental states. Mind is their chief; they are all mind-wrought."</p>
				</blockquote>
			</details>
		</main>
		<style>
			.profile-image-wrapper {
				float: right;
				margin: 0 0 0.75em 1em;
				border-radius: 50%;
				overflow: hidden;
			}
			.profile-image {
				width: 240px;
				height: 240px;
				object-fit: cover;
				border-radius: 50%;
				display: block;
			}
			.first-paragraph {
				overflow: auto;
			}
			@media (max-width: 520px) {
				.profile-image-wrapper {
					float: none;
					margin: 0 0 0.75em 0;
					text-align: center;
				}
				.profile-image {
					margin: 0 auto;
				}
			}
			.site-title {
				font-size: 1.5em;
				font-weight: 600;
				margin-bottom: 0.5em;
			}
			.quotes-section {
				margin-top: 1em;
				padding-top: 0.75em;
				border-top: 1px solid rgb(var(--gray-light));
				font-size: 0.72em;
			}
			.quotes-summary {
				font-size: 1em;
				margin-bottom: 0.5em;
				cursor: pointer;
				list-style: none;
				user-select: none;
			}
			.quotes-summary::-webkit-details-marker {
				display: none;
			}
			.quotes-summary::before {
				content: '▸ ';
				display: inline-block;
				transition: transform 0.2s ease;
			}
			.quotes-section[open] .quotes-summary::before {
				transform: rotate(90deg);
			}
			.quote-card {
				margin: 0 0 0.5em 0;
				padding: 0.35em 0.5em;
				background: rgba(255, 255, 255, 0.6);
				border-radius: 3px;
				border-left: 2px solid var(--accent);
			}
			.quote-card p {
				margin: 0 0 0.15em 0;
			}
			.quote-card p:last-of-type {
				margin-bottom: 0;
			}
			.quote-card cite {
				display: block;
				font-size: 0.9em;
				color: rgb(var(--gray));
				font-style: normal;
				margin-top: 0.15em;
			}
			.quote-source {
				font-size: 0.85em;
				color: rgb(var(--gray));
				margin-bottom: 0.15em !important;
			}
			.quote-text-devanagari {
				font-size: 1em;
				line-height: 1.3;
			}
			.quote-translation {
				font-style: italic;
				color: rgb(var(--gray-dark));
			}
		</style>
		<Footer />
	</body>
</html>
